# ; Security & Stability Configuration for this service
# ; This configuration ensures supply chain security and dependency consistency

# ; Minimum age for packages (7 days in minutes) to reduce risk of malicious packages
# minimum-release-age=10080

# ; Enable npm audit and fail on low severity vulnerabilities
# audit=true
# audit-level=low

# ; Enforce strict Node.js engine matching across all environments
# engine-strict=true

# ; Pin exact versions to prevent unexpected updates
# save-exact=true

# ; Fail on unresolved peer dependencies
# strict-peer-deps=true

# ; Disable legacy peer deps resolution (security risk)
# legacy-peer-deps=false

# ; Maintain consistent dependency tree
# ; package-lock=true

# ; Verify package provenance for supply chain verification
# provenance=true

# ; Disable execution of arbitrary scripts from packages
# ignore-scripts=false

# ; Consider more restrictive script control
# ; ignore-scripts=false  # You have this - consider changing to true for stricter security

# ; Alternative: allow only specific scripts
# ; But ignore-scripts=true would prevent postinstall malware

# ; Ensure lockfile matches package.json
# package-lock=true

# ; Use strict lockfile version
# lockfile-version=3

# ; Reject packages not in lockfile
# resolve-lockfile-version=true

# ; Enforce HTTPS only
# registry=https://registry.npmjs.org/

# ; Verify registry integrity
# strict-ssl=true
# ca=null  # Use system CA certificates

# ; Validate cache integrity
# cache=/path/to/cache
# verify-cache=true

# ; Force integrity checking
# integrity=true

# ; Prevent platform-specific binaries if not needed
# optional=false

# ; Or be explicit about allowed platforms
# ; platform=linux,win32,darwin
