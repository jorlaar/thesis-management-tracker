{
    "compilerOptions": {
      "target": "ES2022",
      "module": "ES2022",
      "lib": ["ES2022", "esnext.asynciterable", "dom"],
      "sourceMap": true,
      "outDir": "./dist",
      "rootDir": "./src",
      "strict": false,
      "noImplicitAny": false,
      "noUnusedLocals": true,
      "moduleResolution": "node",
      "baseUrl": "./src",
      "paths": {
        "@app/common/*": ["common/*"],
        "@app/data/*": ["data/*"],
        "@app/server/*": ["server/*"]
      },
      "typeRoots": ["./node_modules/@types", "./typings"],
      "types": ["jest"],
      "esModuleInterop": true,
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true
    },
    "exclude": ["src/**/*.spec.ts", "src/__tests__/**"],
    "include": ["typings/**/*.d.ts", "src/**/*"]
  }
